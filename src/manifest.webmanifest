{
  "name": "Farkle",
  "short_name": "Farkle",
  "description": "Score keeping app for the Farkle dice game",
  "theme_color": "#1565c0",
  "background_color": "#fafafa",
  "start_url": "/en/",
  "scope": "/",
  "lang": "en",
  "icons": [
    {
      "src": "assets/icon_sm.png",
